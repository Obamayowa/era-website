# ── Database ────────────────────────────────────────────────────
# Railway provides this automatically when you add a PostgreSQL service.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/era_emergent"

# ── Server ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ────────────────────────────────────────────────────────
# Set this to your Cloudflare Pages URL in production
# e.g. https://era-emergent.pages.dev
CORS_ORIGIN="http://localhost:5173"

# ── File uploads ─────────────────────────────────────────────────
# Local path where uploaded files are stored.
# On Railway, use a Volume or swap this for Cloudflare R2 / S3.
UPLOAD_DIR="./uploads"

# ── Stripe (optional – for future payments) ──────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
