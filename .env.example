# ── API base URL ─────────────────────────────────────────────────
# In development this points to the local Express backend.
# In production, set this to your Railway deployment URL.
# e.g. https://era-backend-production.up.railway.app
VITE_API_URL="http://localhost:3001"

# ── Sanity CMS ───────────────────────────────────────────────────
# Get these from manage.sanity.io after creating your project
VITE_SANITY_PROJECT_ID="your_project_id_here"
VITE_SANITY_DATASET="production"
